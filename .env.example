# Glean instance name (the subdomain, e.g. "mycompany" from mycompany.glean.com)
GLEAN_INSTANCE=your-instance

# Indexing API token (from Glean Admin > Setup > APIs & Connectors > API Tokens)
# This token is used for the Indexing API only
GLEAN_INDEXING_TOKEN=your-indexing-token

# Search API token — used for the Search API
GLEAN_USER_TOKEN=your-search-token

# Client/Chat API token — used for the Chat API (falls back to GLEAN_USER_TOKEN if not set)
# GLEAN_CHAT_TOKEN=your-chat-token

# The datasource name to index documents into (must be pre-registered or created via API)
GLEAN_DATASOURCE=glean-mcp-exercise

# Required when using a Global token: the email address to act as for Search and Chat API calls
# GLEAN_ACT_AS=you@yourcompany.com

# Optional: override the Glean backend base URL (defaults to https://{GLEAN_INSTANCE}-be.glean.com)
# GLEAN_BASE_URL=https://your-instance-be.glean.com
